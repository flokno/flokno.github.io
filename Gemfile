source "https://rubygems.org"

# Mirrors the GitHub Pages build environment. Placing github-pages in the
# :jekyll_plugins group makes `bundle exec jekyll build` load it, which force-
# enables the same plugin set Pages uses (jekyll-readme-index turns README.md
# into index.html, jekyll-seo-tag, jekyll-github-metadata, ...).
gem "github-pages", group: :jekyll_plugins
